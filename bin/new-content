#!/bin/bash
# new-content — Generate a new content idea file from template
# Usage: ./new-content "Your Idea Title"

set -e

TITLE="${1:-Untitled Idea}"
DATE=$(date +%Y-%m-%d)
SAFE_TITLE=$(echo "$TITLE" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd '[:alnum:]-')
FILENAME="${DATE}-${SAFE_TITLE}.md"
CONTENT_DIR="${CONTENT_DIR:-./content}"

mkdir -p "$CONTENT_DIR"

cat > "$CONTENT_DIR/$FILENAME" << EOF
# Content Idea: $TITLE

**Date Captured:** $DATE  
**Status:** ideation  
**Priority:** high  
**Format:** [YouTube long-form | TikTok/Reel | Shorts | Twitter/X thread]

---

## Core Concept
**One-liner:** [Describe in one sentence]

## Hook (First 3-5 seconds)
- **Visual hook:** [What they see immediately]
- **Audio hook:** [Opening line/wording]
- **Pattern interrupt:** [What makes them stop scrolling]

## Angle / Unique Take
[What's YOUR perspective? Why are YOU the person to make this?]

## Target Audience
- **Primary:** [Who needs this most?]
- **Their pain point:** [What problem does this solve?]
- **Their desired outcome:** [What transformation after watching?]

## Research Needed
- [ ] Fact/source 1
- [ ] Fact/source 2
- [ ] Example/case study
- [ ] Data/statistics

## Related Ideas (for series potential)
1. [Spin-off idea 1]
2. [Spin-off idea 2]

## Notes / Random Thoughts
[Brain dump — connections, visuals, references]
EOF

echo "✅ Created: $CONTENT_DIR/$FILENAME"
echo "📝 Next: Fill out the template and move it through your pipeline!"
